# Copy to .env (git-ignored) for local development, and set the same keys in
# the AWS Amplify console (App settings -> Environment variables) for prod.
# These are read by api/chat.js and api/send-lead.js. Never commit real values.

# OpenAI API key used by api/chat.js for the assistant replies.
OPENAI_API_KEY=

# SendGrid API key used by api/send-lead.js to send lead notification and
# confirmation emails.
SENDGRID_API_KEY=

# Zapier Catch Hook that receives every successful lead (contact form,
# ContactSection, calculator, chatbot) with full tracking fields. Kept out of
# the (public) repo and browser code — server-side only.
ZAPIER_WEBHOOK_URL=
